{
  "name": "classic-radio",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "build:cli": "cargo build --manifest-path src-tauri/Cargo.toml --bin classic-radio-cli",
    "build:cli:release": "cargo build --release --manifest-path src-tauri/Cargo.toml --bin classic-radio-cli",
    "test": "node --test",
    "check": "npm run test && npm run build && cargo check --manifest-path src-tauri/Cargo.toml && cargo check --manifest-path src-tauri/Cargo.toml --bin classic-radio-cli",
    "format": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "deb": "npm run build:cli:release && tauri build --bundles deb"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "hls.js": "^1.6.16"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "vite": "^7.0.0"
  }
}
