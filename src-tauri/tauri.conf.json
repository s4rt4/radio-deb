{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Classic Radio",
  "version": "0.2.0",
  "identifier": "id.sarta.classic-radio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Classic Radio",
        "width": 430,
        "height": 560,
        "minWidth": 390,
        "minHeight": 520,
        "resizable": true,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; media-src http: https:; connect-src http: https: ws: wss: ipc: http://ipc.localhost; worker-src 'self' blob:; child-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon-512.png",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Classic radio streaming player",
    "longDescription": "Classic Radio is a Debian desktop radio streaming player with station management and system tray controls.",
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
